#!/usr/bin/env bash
# kapp-service-install — run the Claude + Telegram bot as an always-on service
# (auto-restart on crash/OOM, start on boot). Opt-in replacement for the manual
# `tmux` flow. Run as your non-root sudo user.
#
# One mode: systemd supervises the runner, and the runner starts Claude inside
# an attachable tmux session (`tmux attach -t claude`) — claude needs a PTY, so
# a pure-headless variant no longer exists.
#
# Idempotent: re-running re-installs the unit and restarts the service.
#   KAPP_PROVISION_BASE_URL   override the provision/ raw base URL (optional)

set -euo pipefail

log()  { printf '\n\033[1;36m==> %s\033[0m\n' "$*"; }
warn() { printf '\033[1;33m[warn]\033[0m %s\n' "$*"; }
die()  { printf '\033[1;31m[err]\033[0m  %s\n' "$*" >&2; exit 1; }

case "${1:-}" in
  "") ;;
  --tmux|--headless) warn "'$1' is obsolete — there is one mode now (systemd + tmux runner). Continuing." ;;
  *) die "Unknown option '$1'." ;;
esac

[[ "$(id -u)" -ne 0 ]] || die "Run as your non-root sudo user, not root — Claude refuses --dangerously-skip-permissions as root."
command -v systemctl >/dev/null || die "systemd (systemctl) not found — this installer needs systemd."
command -v sudo >/dev/null      || die "sudo not found."
command -v tmux >/dev/null      || die "tmux not found — install it first (sudo apt-get install tmux); the runner starts Claude inside tmux."
command -v claude >/dev/null    || warn "claude not on PATH yet — finish setup-vps.sh + 'claude' login first, or the service will just wait."

USER_NAME="$(id -un)"
RAW_BASE="${KAPP_PROVISION_BASE_URL:-https://raw.githubusercontent.com/KAppMaker/KAppMakerDeveloperBot/main/provision}"
UNIT_SRC="claude-telegram.service"

# --- runner script -> ~/bin ---
log "Installing runner to ~/bin/claude-telegram-run.sh"
mkdir -p "$HOME/bin"
curl -fsSL "$RAW_BASE/claude-telegram-run.sh" -o "$HOME/bin/claude-telegram-run.sh"
chmod +x "$HOME/bin/claude-telegram-run.sh"

# --- systemd unit (always named claude-telegram.service; substitute the user) ---
log "Installing systemd unit for user '$USER_NAME'"
TMP_UNIT="$(mktemp)"
curl -fsSL "$RAW_BASE/$UNIT_SRC" -o "$TMP_UNIT"
sed "s/__DEVUSER__/$USER_NAME/g" "$TMP_UNIT" | sudo tee /etc/systemd/system/claude-telegram.service >/dev/null
rm -f "$TMP_UNIT"

# --- enable + (re)start to pick up the new unit ---
sudo systemctl daemon-reload
sudo systemctl enable claude-telegram.service >/dev/null 2>&1 || true
sudo systemctl restart claude-telegram.service

if [[ ! -f "$HOME/.config/kappmaker/env" ]]; then
  warn "No ~/.config/kappmaker/env found — Gradle/Android builds under the service may miss JAVA_HOME/ANDROID_SDK_ROOT."
  warn "Re-run setup-vps.sh to generate it (the service loads it automatically)."
fi

echo ""
echo "────────────────────────────────────────────────────────────"
echo "Always-on service installed. Auto-restarts on crash and starts on boot."
echo ""
echo "  Watch it live:  tmux attach -t claude      (detach: Ctrl+B then D)"
echo "                  (if attach can't find it: TMUX_TMPDIR=/tmp tmux attach -t claude)"
echo "  Logs:           journalctl -fu claude-telegram"
echo "  Status:         systemctl status claude-telegram"
echo "  Stop/start:     sudo systemctl stop|start claude-telegram"
echo ""
echo "IMPORTANT: stop any 'claude' you started by hand in your own tmux. Two Claude"
echo "sessions polling the same Telegram bot token conflict (each update goes to one)."
echo "────────────────────────────────────────────────────────────"
